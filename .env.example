# Environment variables for DropwizardEmployee service

# Default name for the template (used in example.yml via ${DW_DEFAULT_NAME:-Stranger})
DW_DEFAULT_NAME=Docker User

# Graphite host for metrics collection (used in example.yml via ${GRAPHITE_HOST:-localhost})
GRAPHITE_HOST=graphite

# Optional: Override database URL (if needed for external database)
# DATABASE_URL=jdbc:h2:/app/data/example

# Optional: Override logging level
# LOG_LEVEL=INFO

# Optional: Override server ports (if needed)
# APP_PORT=8080
# ADMIN_PORT=8081
